/* ====== CONTENT MODE ====== */
function buildContent(sel){
  const q = sel.quote || "";
  const arche = sel.archetype || "Reader";
  const mood = sel.mood || "bookish";
  const att = sel.attitude || "unbothered";
  const rx = sel.reaction || "reaction";
  const theme = sel.dropTheme || "";

  const captions = [
    `${arche} energy: ${att}.`,
    `Me reading this like: ${rx}.`,
    `This chapter had me in ${mood}.`,
    `Readerverse check-in: ${arche}.`,
    `If you get it, you get it. ${arche} edition.`
  ];
  const hooks = [
    "Be honest… what would your face be right here?",
    "Drop your reaction type in the comments 👇",
    "Which reader archetype are you today?",
    "Tag your book bestie who would scream at this scene.",
    "This is the part where I start speed-reading and spiraling."
  ];
  const hashtags = [
    "#BookishDemands","#Readerverse","#BookTok","#Bookstagram",
    "#RomanceReaders","#DarkRomance","#ReadingCommunity","#BookishHumor",
    "#EReaderGirlies","#ReaderReactions","#StickerShop","#DigitalDownloads"
  ];

  const t = normalize(q);
  if(t.includes("plot twist") || t.includes("twist")) hashtags.push("#PlotTwist");
  if(t.includes("villain") || t.includes("morally")) hashtags.push("#MorallyGrey");
  if(t.includes("obsessed") || t.includes("mine") || t.includes("possessive") || t.includes("ruin")) hashtags.push("#ObsessedMMC");
  if(theme) hashtags.push("#" + theme.replace(/\s+/g,""));

  return {
    caption: pick(captions) + (q ? `\n\n“${q}”` : ""),
    hook: pick(hooks),
    hashtags: Array.from(new Set(hashtags)).join(" ")
  };
}

