<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1"/>
  <title>Bookish Demands Readerverse Engine</title>
  <style>
    :root{
      --bg:#0c0c10;
      --panel:#151523;
      --panel2:#1c1c2e;
      --text:#f2f2f7;
      --muted:#b7b7c9;
      --accent:#E0009A;
      --accent2:#7c3aed;
      --line:#2a2a3f;
      --good:#22c55e;
      --warn:#f59e0b;
      --bad:#ef4444;
    }
    *{ box-sizing:border-box; }
    body{
      margin:0;
      font-family: ui-sans-serif, system-ui, -apple-system, Segoe UI, Roboto, Arial, "Helvetica Neue", "Noto Sans", sans-serif;
      background: radial-gradient(1200px 700px at 20% 0%, rgba(224,0,154,.18), transparent 60%),
                  radial-gradient(1000px 700px at 85% 10%, rgba(124,58,237,.12), transparent 60%),
                  var(--bg);
      color:var(--text);
    }
    header{
      padding:20px 18px 12px;
      border-bottom:1px solid var(--line);
      background: linear-gradient(180deg, rgba(21,21,35,.85), rgba(12,12,16,.35));
      position:sticky;
      top:0;
      z-index:5;
      backdrop-filter: blur(10px);
    }
    .wrap{ max-width:1200px; margin:0 auto; }
    h1{ margin:0; font-size:18px; letter-spacing:.2px; }
    .sub{ margin:6px 0 0; color:var(--muted); font-size:13px; line-height:1.4; }
    .pill{
      display:inline-block;
      padding:4px 10px;
      border:1px solid var(--line);
      border-radius:999px;
      color:var(--muted);
      font-size:12px;
      margin-top:10px;
    }
    main{ padding:18px; }
    .grid{
      display:grid;
      grid-template-columns: 1.25fr .75fr;
      gap:14px;
    }
    @media (max-width: 980px){
      .grid{ grid-template-columns: 1fr; }
      header{ position:relative; }
    }
    .card{
      background: linear-gradient(180deg, rgba(21,21,35,.95), rgba(21,21,35,.75));
      border:1px solid var(--line);
      border-radius:14px;
      padding:14px;
    }
    .card h2{
      margin:0 0 10px;
      font-size:14px;
      color:#fff;
      letter-spacing:.2px;
    }
    .row{
      display:grid;
      grid-template-columns: 1fr 1fr;
      gap:10px;
      margin-bottom:10px;
    }
    @media (max-width: 720px){
      .row{ grid-template-columns: 1fr; }
    }
    label{
      display:block;
      font-size:12px;
      color:var(--muted);
      margin:0 0 6px;
    }
    select, input[type="text"], input[type="password"], textarea{
      width:100%;
      padding:10px 10px;
      border-radius:10px;
      border:1px solid var(--line);
      background: var(--panel2);
      color: var(--text);
      outline:none;
    }
    textarea{ min-height:86px; resize:vertical; }
    .btnrow{
      display:flex;
      flex-wrap:wrap;
      gap:10px;
      margin-top:10px;
    }
    button{
      border:0;
      border-radius:12px;
      padding:10px 12px;
      background: var(--panel2);
      border:1px solid var(--line);
      color:var(--text);
      cursor:pointer;
      font-weight:700;
      font-size:13px;
    }
    button.primary{
      background: linear-gradient(90deg, rgba(224,0,154,1), rgba(124,58,237,1));
      border:0;
    }
    button.good{ border-color: rgba(34,197,94,.55); }
    button.warn{ border-color: rgba(245,158,11,.55); }
    button.bad{ border-color: rgba(239,68,68,.55); }
    button:active{ transform: translateY(1px); }
    .toggle{
      display:flex;
      gap:10px;
      align-items:center;
      padding:10px;
      border:1px solid var(--line);
      border-radius:12px;
      background: rgba(28,28,46,.65);
      margin-top:10px;
    }
    .toggle input{ transform: scale(1.2); }
    .note{
      font-size:12px;
      color:var(--muted);
      line-height:1.4;
      margin-top:8px;
    }
    .out{
      background: #0b0b13;
      border:1px solid var(--line);
      border-radius:14px;
      padding:12px;
      margin-top:10px;
    }
    .out pre{
      margin:0;
      white-space:pre-wrap;
      word-break:break-word;
      font-size:12.5px;
      color:#f7f7ff;
      line-height:1.45;
    }
    .divider{
      height:1px;
      background: var(--line);
      margin:12px 0;
    }
    .chips{ display:flex; flex-wrap:wrap; gap:8px; margin-top:10px; }
    .chip{
      display:inline-flex;
      gap:8px;
      align-items:center;
      padding:8px 10px;
      border:1px solid var(--line);
      border-radius:999px;
      background: rgba(28,28,46,.55);
      font-size:12px;
      color:var(--muted);
    }
    .badge{
      display:inline-block;
      padding:3px 8px;
      border-radius:10px;
      background: rgba(224,0,154,.18);
      border:1px solid rgba(224,0,154,.35);
      color:#ffd3f2;
      font-size:12px;
      margin-left:8px;
    }

    /* Access Gate */
    #gateWrap{
      position:fixed;
      inset:0;
      background: rgba(5,5,10,.92);
      display:flex;
      align-items:center;
      justify-content:center;
      padding:18px;
      z-index:9999;
    }
    .gateCard{
      max-width:520px;
      width:100%;
      background: linear-gradient(180deg, rgba(21,21,35,.98), rgba(21,21,35,.78));
      border:1px solid var(--line);
      border-radius:16px;
      padding:16px;
    }
    .gateTitle{
      font-size:16px;
      margin:0 0 6px;
    }
    .gateSub{
      margin:0 0 12px;
      color:var(--muted);
      font-size:12.5px;
      line-height:1.4;
    }
    .gateRow{
      display:grid;
      grid-template-columns: 1fr auto;
      gap:10px;
      align-items:end;
    }
    .tiny{
      font-size:11.5px;
      color:var(--muted);
      margin-top:10px;
      line-height:1.4;
    }
  </style>
</head>
<body>

<!-- OPTIONAL ACCESS GATE (Phase 1 protection) -->
<div id="gateWrap" style="display:none;">
  <div class="gateCard">
    <h3 class="gateTitle">Readerverse Engine Access</h3>
    <p class="gateSub">Enter your access password to unlock the tool.</p>
    <div class="gateRow">
      <div>
        <label for="gatePass">Password</label>
        <input id="gatePass" type="password" placeholder="Enter password"/>
      </div>
      <button class="primary" id="gateBtn">Unlock</button>
    </div>
    <div class="tiny">
      Note: This is a simple access gate for “lifetime access” products. For stronger protection later, we can add license keys / purchase validation.
    </div>
  </div>
</div>

<header>
  <div class="wrap">
    <h1>Bookish Demands Readerverse Engine <span class="badge">v1.4</span></h1>
    <div class="sub">
      Smart Archetype DNA + Reaction Packs + Carousel Generator + Drop Builder. Single-file HTML. Trademark-safe: uses “e-reader.”
    </div>
    <div class="pill">Tip: Use a quote → run <b>Reaction Pack</b> or <b>Carousel</b> for instant viral content.</div>
  </div>
</header>

<main class="wrap">
  <div class="grid">

    <!-- LEFT -->
    <section class="card">
      <h2>Builder</h2>

      <div class="row">
        <div>
          <label for="mode">Generator Mode</label>
          <select id="mode">
            <option value="single">Single Character</option>
            <option value="match">Match Character to Quote</option>
            <option value="reaction4">Reaction Pack (4)</option>
            <option value="carousel4">Carousel Generator (4 slides)</option>
            <option value="pack10">10-Pack From Quote</option>
            <option value="pack30">30-Pack (Full Product Drop)</option>
            <option value="dropbuilder">Drop Builder (Theme → 30 Pack)</option>
            <option value="batch5">Generate 5 Characters (Random)</option>
          </select>
        </div>
        <div>
          <label for="matchStrength">Matching Strength</label>
          <select id="matchStrength">
            <option value="balanced">Balanced</option>
            <option value="ontheme">On-theme</option>
            <option value="super">Super on-theme</option>
          </select>
        </div>
      </div>

      <div class="row" id="dropRow">
        <div>
          <label for="dropTheme">Drop Theme</label>
          <select id="dropTheme"></select>
        </div>
        <div>
          <label for="dropName">Drop Name (auto or custom)</label>
          <input id="dropName" type="text" placeholder="Example: Delusional But Calculated — Volume 1"/>
          <div class="note">Leave blank to auto-name based on theme + quote usage.</div>
        </div>
      </div>

      <div class="toggle">
        <input id="smartArchetype" type="checkbox" checked />
        <label for="smartArchetype" style="margin:0;color:var(--text);font-size:13px;">Smart Archetype DNA</label>
        <span class="note" style="margin:0;">(auto-locks expression/pose/props based on archetype)</span>
      </div>

      <div class="toggle">
        <input id="contentMode" type="checkbox" checked />
        <label for="contentMode" style="margin:0;color:var(--text);font-size:13px;">Content Generator Mode</label>
        <span class="note" style="margin:0;">(caption + hook + hashtags)</span>
      </div>

      <div class="toggle">
        <input id="carouselMode" type="checkbox" checked />
        <label for="carouselMode" style="margin:0;color:var(--text);font-size:13px;">Carousel / Sticker Composition Mode</label>
        <span class="note" style="margin:0;">(clean, centered, big expression)</span>
      </div>

      <div class="toggle">
        <input id="noText" type="checkbox" checked />
        <label for="noText" style="margin:0;color:var(--text);font-size:13px;">Force “NO TEXT”</label>
        <span class="note" style="margin:0;">(recommended)</span>
      </div>

      <div class="divider"></div>

      <div class="row">
        <div>
          <label for="quoteInput">Quote (for matching / packs / carousel)</label>
          <textarea id="quoteInput" placeholder="Paste your quote here."></textarea>
        </div>
        <div>
          <label for="customCategory">Custom Notes (optional)</label>
          <input id="customCategory" type="text" placeholder="Example: trope tags, vibe notes, drop era"/>
          <div class="note">Appends as “custom notes: …”</div>
        </div>
      </div>

      <div class="row">
        <div>
          <label for="customAddons">Custom Add-ons (comma-separated)</label>
          <input id="customAddons" type="text" placeholder="extra dramatic lashes, oversized glasses, glossy highlight, nose ring"/>
          <div class="note">Fast micro-details without editing dropdowns.</div>
        </div>
        <div>
          <label for="customCategories">Custom Categories (one per line: Label: value)</label>
          <textarea id="customCategories" placeholder="Lashes: extra dramatic manga lashes&#10;Glasses: oversized gold rim glasses"></textarea>
          <div class="note">Turns into prompt lines automatically.</div>
        </div>
      </div>

      <div class="row">
        <div>
          <label for="negativePrompt">Avoid / Negative Prompt</label>
          <textarea id="negativePrompt" placeholder="avoid: masculine face, harsh jawline, thick brows, realism, blurry, low quality, watermark, logo"></textarea>
        </div>
        <div>
          <label for="carouselTitleStyle">Carousel Text Style (optional)</label>
          <select id="carouselTitleStyle">
            <option value="none">No slide titles (clean)</option>
            <option value="short">Short slide titles</option>
            <option value="spicy">Sassy slide titles</option>
          </select>
          <div class="note">Carousel mode outputs slide text guidance (you can paste into Canva).</div>
        </div>
      </div>

      <div class="btnrow">
        <button class="primary" id="btnGenerate">Build Output</button>
        <button class="good" id="btnRandom">One-Click Random Character</button>
        <button id="btnCopy">Copy Output</button>
      </div>

      <div class="divider"></div>

      <!-- Core dropdowns -->
      <div class="row">
        <div>
          <label for="archetype">Reader Archetype</label>
          <select id="archetype"></select>
        </div>
        <div>
          <label for="expression">Expression</label>
          <select id="expression"></select>
        </div>
      </div>

      <div class="row">
        <div>
          <label for="micro">Micro Expression</label>
          <select id="micro"></select>
        </div>
        <div>
          <label for="reaction">Reader Reaction</label>
          <select id="reaction"></select>
        </div>
      </div>

      <div class="row">
        <div>
          <label for="mood">Reader Mood</label>
          <select id="mood"></select>
        </div>
        <div>
          <label for="attitude">Attitude / Personality</label>
          <select id="attitude"></select>
        </div>
      </div>

      <div class="row">
        <div>
          <label for="pose">Pose</label>
          <select id="pose"></select>
        </div>
        <div>
          <label for="poseAtt">Pose Attitude</label>
          <select id="poseAtt"></select>
        </div>
      </div>

      <div class="row">
        <div>
          <label for="complexion">Melanated Complexion</label>
          <select id="complexion"></select>
        </div>
        <div>
          <label for="bodyType">Body Type</label>
          <select id="bodyType"></select>
        </div>
      </div>

      <div class="row">
        <div>
          <label for="faceShape">Face Shape</label>
          <select id="faceShape"></select>
        </div>
        <div>
          <label for="extras">Extras (lashes / glasses / piercings)</label>
          <select id="extras"></select>
        </div>
      </div>

      <div class="row">
        <div>
          <label for="hairColor">Hair Color</label>
          <select id="hairColor"></select>
        </div>
        <div>
          <label for="hair">Hair Style</label>
          <select id="hair"></select>
        </div>
      </div>

      <div class="row">
        <div>
          <label for="makeup">Makeup</label>
          <select id="makeup"></select>
        </div>
        <div>
          <label for="lighting">Lighting</label>
          <select id="lighting"></select>
        </div>
      </div>

      <div class="row">
        <div>
          <label for="nailShape">Nail Shape / Style</label>
          <select id="nailShape"></select>
        </div>
        <div>
          <label for="nailDesign">Nail Color / Design</label>
          <select id="nailDesign"></select>
        </div>
      </div>

      <div class="row">
        <div>
          <label for="outfit">Outfit</label>
          <select id="outfit"></select>
        </div>
        <div>
          <label for="accessories">Jewelry / Accessories</label>
          <select id="accessories"></select>
        </div>
      </div>

      <div class="row">
        <div>
          <label for="prop">Bookish Props</label>
          <select id="prop"></select>
        </div>
        <div>
          <label for="scene">Scene</label>
          <select id="scene"></select>
        </div>
      </div>

      <div class="row">
        <div>
          <label for="background">Background</label>
          <select id="background"></select>
        </div>
        <div>
          <label for="palette">Palette</label>
          <select id="palette"></select>
        </div>
      </div>

      <div class="row">
        <div>
          <label for="composition">Composition</label>
          <select id="composition"></select>
        </div>
        <div></div>
      </div>

      <div class="divider"></div>

      <h2>Quick Add (build your vault on the fly)</h2>
      <div class="row">
        <div>
          <label for="addTarget">Add to…</label>
          <select id="addTarget">
            <option value="archetype">Archetype</option>
            <option value="expression">Expression</option>
            <option value="micro">Micro Expression</option>
            <option value="reaction">Reaction</option>
            <option value="mood">Mood</option>
            <option value="attitude">Attitude</option>
            <option value="pose">Pose</option>
            <option value="poseAtt">Pose Attitude</option>
            <option value="complexion">Complexion</option>
            <option value="bodyType">Body Type</option>
            <option value="faceShape">Face Shape</option>
            <option value="extras">Extras</option>
            <option value="hairColor">Hair Color</option>
            <option value="hair">Hair</option>
            <option value="makeup">Makeup</option>
            <option value="lighting">Lighting</option>
            <option value="nailShape">Nail Shape</option>
            <option value="nailDesign">Nail Design</option>
            <option value="outfit">Outfit</option>
            <option value="accessories">Accessories</option>
            <option value="prop">Prop</option>
            <option value="background">Background</option>
            <option value="scene">Scene</option>
            <option value="palette">Palette</option>
            <option value="composition">Composition</option>
            <option value="dropTheme">Drop Theme</option>
          </select>
        </div>
        <div>
          <label for="addValue">New option text</label>
          <input id="addValue" type="text" placeholder="Type a new option then click Add"/>
        </div>
      </div>
      <div class="btnrow">
        <button id="btnAddOption">Add Option</button>
        <button class="bad" id="btnResetDefaults">Reset to Defaults</button>
      </div>
      <div class="note">Reset restores original lists (presets + drop library remain).</div>
    </section>

    <!-- RIGHT -->
    <aside class="card">
      <h2>Output</h2>
      <div class="out"><pre id="output">(Click “Build Output”)</pre></div>

      <div class="btnrow">
        <button id="btnExportTXT">Export TXT</button>
        <button id="btnExportCSV">Export CSV</button>
        <button id="btnExportDropJSON">Export Drop JSON</button>
      </div>

      <div class="divider"></div>

      <h2>Drop Library</h2>
      <div class="row">
        <div>
          <label for="dropLibSelect">Saved Drops</label>
          <select id="dropLibSelect"></select>
        </div>
        <div>
          <label>&nbsp;</label>
          <div class="note">Saves in your browser. Export JSON to back up.</div>
        </div>
      </div>
      <div class="btnrow">
        <button class="good" id="btnSaveDrop">Save Current Drop</button>
        <button id="btnLoadDrop">Load Drop</button>
        <button class="bad" id="btnDeleteDrop">Delete Drop</button>
      </div>
      <div class="btnrow">
        <button id="btnExportDropLibrary">Export Drop Library (JSON)</button>
        <button id="btnImportDropLibrary">Import Drop Library (JSON)</button>
      </div>
      <input id="importDropLibFile" type="file" accept="application/json" style="display:none"/>

      <div class="divider"></div>

      <h2>Presets</h2>
      <div class="row">
        <div>
          <label for="presetName">Preset name</label>
          <input id="presetName" type="text" placeholder="Example: Petty Reader — Side Eye"/>
        </div>
        <div>
          <label for="presetSelect">Saved presets</label>
          <select id="presetSelect"></select>
        </div>
      </div>
      <div class="btnrow">
        <button class="good" id="btnSavePreset">Save Preset</button>
        <button id="btnLoadPreset">Load Preset</button>
        <button class="bad" id="btnDeletePreset">Delete Preset</button>
      </div>
      <div class="btnrow">
        <button id="btnExportPresets">Export Presets (JSON)</button>
        <button id="btnImportPresets">Import Presets (JSON)</button>
      </div>
      <input id="importFile" type="file" accept="application/json" style="display:none"/>

      <div class="divider"></div>

      <h2>Fast products</h2>
      <div class="chips">
        <span class="chip">Reaction carousels</span>
        <span class="chip">30-pack sticker drops</span>
        <span class="chip">E-reader insert prompts</span>
        <span class="chip">Character packs</span>
        <span class="chip">Caption + hook output</span>
      </div>
      <div class="note">Best workflow: paste quote → <b>Reaction Pack</b> or <b>Carousel</b> → export CSV.</div>
    </aside>

  </div>
</main>

