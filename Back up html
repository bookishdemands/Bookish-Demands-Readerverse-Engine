/* ====== HELPERS ====== */
const $ = (id)=>document.getElementById(id);
const pick = (arr)=>arr[Math.floor(Math.random()*arr.length)];
const normalize = (s)=>String(s||"").toLowerCase();

function fillSelect(id, arr){
  const el = $(id);
  el.innerHTML = "";
  arr.forEach(v=>{
    const opt = document.createElement("option");
    opt.value = v;
    opt.textContent = v;
    el.appendChild(opt);
  });
}
function escapeCSV(value){
  const s = String(value ?? "");
  if(/[",\n]/.test(s)) return `"${s.replace(/"/g,'""')}"`;
  return s;
}
function downloadText(filename, text){
  const blob = new Blob([text], {type:"text/plain;charset=utf-8"});
  const url = URL.createObjectURL(blob);
  const a = document.createElement("a");
  a.href = url; a.download = filename;
  document.body.appendChild(a);
  a.click();
  a.remove();
  URL.revokeObjectURL(url);
}
function buildCSV(rows){
  const headers = ["label","dropName","dropTheme","quoteReference","prompt","caption","hook","hashtags","slideText"];
  const lines = [headers.join(",")];
  rows.forEach(r=>{
    lines.push([
      escapeCSV(r.label||""),
      escapeCSV(r.dropName||""),
      escapeCSV(r.dropTheme||""),
      escapeCSV(r.quoteReference||""),
      escapeCSV(r.prompt||""),
      escapeCSV(r.caption||""),
      escapeCSV(r.hook||""),
      escapeCSV(r.hashtags||""),
      escapeCSV(r.slideText||"")
    ].join(","));
  });
  return lines.join("\n");
}

