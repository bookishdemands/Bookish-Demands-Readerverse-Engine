function refreshPresetSelect(){
  const sel = $("presetSelect");
  sel.innerHTML = "";
  const names = Object.keys(PRESETS).sort((a,b)=>a.localeCompare(b));
  const blank = document.createElement("option");
  blank.value = ""; blank.textContent = "— Select —";
  sel.appendChild(blank);
  names.forEach(name=>{
    const opt = document.createElement("option");
    opt.value = name;
    opt.textContent = name;
    sel.appendChild(opt);
  });
}

function refreshDropLibSelect(){
  const sel = $("dropLibSelect");
  sel.innerHTML = "";
  const ids = Object.keys(DROP_LIB).sort((a,b)=>{
    const da = DROP_LIB[a]?.createdAt || "";
    const db = DROP_LIB[b]?.createdAt || "";
    return db.localeCompare(da);
  });

  const blank = document.createElement("option");
  blank.value = ""; blank.textContent = "— Select a saved drop —";
  sel.appendChild(blank);

  ids.forEach(id=>{
    const d = DROP_LIB[id];
    const date = d?.createdAt ? new Date(d.createdAt).toLocaleString() : "";
    const count = d?.rows?.length ?? 0;
    const opt = document.createElement("option");
    opt.value = id;
    opt.textContent = `${d.dropName} • ${d.dropTheme} • ${count} items • ${date}`;
    sel.appendChild(opt);
  });
}

