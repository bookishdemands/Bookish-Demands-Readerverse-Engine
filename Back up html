/* ====== QUOTE MATCHER (lightweight) ====== */
function matchToQuote(data, quoteRaw, strength){
  const quote = normalize(quoteRaw);
  const has = (...words)=>words.some(w=>quote.includes(w));

  // quote-to-archetype picks
  let arche = "Controlled Chaos Reader";

  if(has("humble","quietly","proved me right","prove me right","told you","i knew it","unbothered","as expected","mmhmm","sure","okay then","watching")){
    arche = "Petty Reader";
  } else if(has("plot twist","wait","what","betrayal","shocked","gasp","jaw dropped","screaming","cant believe","can’t believe","insane","wild","twist")){
    arche = "Plot Twist Detective";
  } else if(has("villain","unhinged","toxic","obsessed","mine","possessive","ruin","morally")){
    arche = "Dark Romance Delulu";
  } else if(has("audiobook","headphones","listening")){
    arche = "Audiobook Multitasker";
  } else if(has("soft","gentle","sweet","cozy")){
    arche = "Soft Girl Menace";
  } else if(has("feral","screaming","need him","ruined me")){
    arche = "Morally Gray Enjoyer";
  }

  $("archetype").value = arche;

  // apply DNA if enabled
  if($("smartArchetype").checked){
    applyArchetypeDNA(data, arche);
  }

  // strength adds bias for palette/background (small)
  if(strength === "super"){
    const dna = ARCHETYPE_DNA[arche];
    if(dna?.paletteBias?.length){
      $("palette").value = pick(dna.paletteBias);
    }
  }

  // keep beauty/fit varied
  $("complexion").value = pick(data.complexion);
  $("bodyType").value = pick(data.bodyType);
  $("faceShape").value = pick(data.faceShape);
  $("hairColor").value = pick(data.hairColor);
  $("hair").value = pick(data.hair);
  $("makeup").value = pick(data.makeup);
  $("nailShape").value = pick(data.nailShape);
  $("nailDesign").value = pick(data.nailDesign);
  $("outfit").value = pick(data.outfit);
  $("accessories").value = pick(data.accessories);
}

/* ====== CAROUSEL TEXT BUILDER ====== */
function slideTitles(style){
  if(style === "short") return ["SHOCKED","DELULU","SIDE-EYE","FERAL"];
  if(style === "spicy") return ["WAIT—","I VOLUNTEER.","MHM. SURE.","I SUPPORT THIS."];
  return ["","","",""];
}

/* ====== DROP BUILDER ====== */
function autoDropName(theme, quote){
  const vibe = ["Volume 1","Edition","Pack","Drop","Set"];
  const tag = quote ? " — Quote-Driven" : "";
  return `${theme} ${pick(vibe)}${tag}`;
}

function buildDrop(data){
  const sel = getSelections();
  const theme = sel.dropTheme;
  const quote = sel.quote;
  const name = sel.dropName || autoDropName(theme, quote);

  const original = getSelections();
  const rows = [];

  for(let i=0;i<30;i++){
    randomizeAll(data);

    // steer theme a little by applying DNA to a theme-aligned archetype
    if(sel.smartArchetype){
      // choose archetype based on theme
      const t = normalize(theme);
      let a = $("archetype").value;
      if(t.includes("petty")) a = "Petty Reader";
      else if(t.includes("after dark") || t.includes("morally")) a = "Dark Romance Delulu";
      else if(t.includes("plot twist")) a = "Plot Twist Detective";
      else if(t.includes("audiobook")) a = "Audiobook Multitasker";
      else if(t.includes("soft girl")) a = "Soft Girl Menace";
      else if(t.includes("feral")) a = "Morally Gray Enjoyer";
      $("archetype").value = a;
      applyArchetypeDNA(data, a);
    }

    if(quote) matchToQuote(data, quote, sel.matchStrength);

    const s = getSelections();
    const prompt = buildSinglePrompt(s);
    const content = s.contentMode ? buildContent(s) : null;

    rows.push({
      label: `Drop ${i+1}`,
      dropName: name,
      dropTheme: theme,
      quoteReference: quote,
      prompt,
      caption: content?.caption || "",
      hook: content?.hook || "",
      hashtags: content?.hashtags || "",
      slideText: ""
    });
  }

  applySelections(original);

  return {
    id: (crypto?.randomUUID ? crypto.randomUUID() : ("drop_" + Date.now() + "_" + Math.random().toString(16).slice(2))),
    dropName: name,
    dropTheme: theme,
    quoteReference: quote,
    createdAt: new Date().toISOString(),
    rows
  };
}

/* ====== PACKS ====== */
function buildReactionPack4(data){
  const quote = $("quoteInput").value.trim();
  const original = getSelections();
  const rows = [];

  const roles = [
    { label:"1) Shock reaction reader", arche:"Plot Twist Detective", slide:"Slide 1: Shock reaction" },
    { label:"2) Delulu dark romance reader", arche:"Dark Romance Delulu", slide:"Slide 2: Delulu dark romance" },
    { label:"3) Petty side-eye reader", arche:"Petty Reader", slide:"Slide 3: Petty side-eye" },
    { label:"4) Feral romance reader", arche:"Morally Gray Enjoyer", slide:"Slide 4: Feral romance" }
  ];

  roles.forEach(r=>{
    randomizeAll(data);
    $("archetype").value = r.arche;
    if($("smartArchetype").checked) applyArchetypeDNA(data, r.arche);
    if(quote) matchToQuote(data, quote, $("matchStrength").value);

    const s = getSelections();
    const prompt = buildSinglePrompt(s);
    const content = s.contentMode ? buildContent(s) : null;

    rows.push({
      label: r.label,
      dropName:"",
      dropTheme:"",
      quoteReference: quote,
      prompt,
      caption: content?.caption || "",
      hook: content?.hook || "",
      hashtags: content?.hashtags || "",
      slideText: r.slide
    });
  });

  applySelections(original);
  return rows;
}

function buildCarousel4(data){
  const quote = $("quoteInput").value.trim();
  const style = $("carouselTitleStyle").value;
  const titles = slideTitles(style);

  const rows = buildReactionPack4(data);

  // attach slide titles + micro copy
  rows.forEach((r, idx)=>{
    const title = titles[idx] || "";
    const slideLine = title ? `${title}\n${quote ? `“${quote}”\n` : ""}${r.caption || ""}` : `${quote ? `“${quote}”\n` : ""}${r.caption || ""}`;
    r.slideText = slideLine.trim();
  });

  return rows;
}

function buildPackN(data, n, labelPrefix){
  const quote = $("quoteInput").value.trim();
  const original = getSelections();
  const rows = [];

  for(let i=0;i<n;i++){
    randomizeAll(data);
    if(quote) matchToQuote(data, quote, $("matchStrength").value);

    const s = getSelections();
    const prompt = buildSinglePrompt(s);
    const content = s.contentMode ? buildContent(s) : null;

    rows.push({
      label: `${labelPrefix} ${i+1}`,
      dropName:"",
      dropTheme:"",
      quoteReference: quote,
      prompt,
      caption: content?.caption || "",
      hook: content?.hook || "",
      hashtags: content?.hashtags || "",
      slideText: ""
    });
  }

  applySelections(original);
  return rows;
}

