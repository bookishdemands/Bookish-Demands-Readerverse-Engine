    const parsed = JSON.parse(text);
    const imported = parsed.drops || parsed;
    if(typeof imported !== "object") throw new Error("Invalid format");
    DROP_LIB = { ...DROP_LIB, ...imported };
    saveDropLibrary(DROP_LIB);
    refreshDropLibSelect();
    alert("Drop library imported!");
