  safeSet("reaction", dna.reaction, data.reaction);
  safeSet("mood", dna.mood, data.mood);
  safeSet("attitude", dna.attitude, data.attitude);
  safeSet("pose", dna.pose, data.pose);
  safeSet("poseAtt", dna.poseAtt, data.poseAtt);
  safeSet("extras", dna.extras, data.extras);
  safeSet("lighting", dna.lighting, data.lighting);
  safeSet("background", dna.background, data.background);
  safeSet("prop", dna.prop, data.prop);
  safeSet("scene", dna.scene, data.scene);

  // palette bias
  if(dna.paletteBias && dna.paletteBias.length){
    const options = dna.paletteBias.filter(p => data.palette.includes(p));
    if(options.length) $("palette").value = pick(options);
  }
}

