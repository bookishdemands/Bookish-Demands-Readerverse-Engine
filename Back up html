$("btnGenerate").addEventListener("click", ()=>{
  const sel = getSelections();
  const mode = sel.mode;

  let rows = [];
  let drop = null;

  if(mode === "single"){
    // apply smart DNA if enabled
    if(sel.smartArchetype) applyArchetypeDNA(DATA, sel.archetype);

    const prompt = buildSinglePrompt(sel);
    const content = sel.contentMode ? buildContent(sel) : null;

    $("output").textContent = sel.contentMode
      ? `PROMPT\n${prompt}\n\nCAPTION\n${content.caption}\n\nHOOK\n${content.hook}\n\nHASHTAGS\n${content.hashtags}`
      : prompt;

    rows = [{
      label:"Single",
      dropName:"",
      dropTheme:"",
      quoteReference:sel.quote,
      prompt,
      caption: content?.caption || "",
      hook: content?.hook || "",
      hashtags: content?.hashtags || "",
      slideText:""
    }];
  }

  if(mode === "match"){
    if(!sel.quote){ alert("Paste a quote first."); return; }
    matchToQuote(DATA, sel.quote, sel.matchStrength);

    const s = getSelections();
    const prompt = buildSinglePrompt(s);
    const content = s.contentMode ? buildContent(s) : null;

    $("output").textContent = s.contentMode
      ? `PROMPT\n${prompt}\n\nCAPTION\n${content.caption}\n\nHOOK\n${content.hook}\n\nHASHTAGS\n${content.hashtags}`
      : prompt;

    rows = [{
      label:"Matched",
      dropName:"",
      dropTheme:"",
      quoteReference:sel.quote,
      prompt,
      caption: content?.caption || "",
      hook: content?.hook || "",
      hashtags: content?.hashtags || "",
      slideText:""
    }];
  }

  if(mode === "reaction4"){
    if(!sel.quote){ alert("Paste a quote for Reaction Pack (4)."); return; }
    rows = buildReactionPack4(DATA);

    $("output").textContent = rows.map(r=>{
      return sel.contentMode
        ? `${r.label}\nPROMPT\n${r.prompt}\n\nCAPTION\n${r.caption}\n\nHOOK\n${r.hook}\n\nHASHTAGS\n${r.hashtags}`
        : `${r.label}\n${r.prompt}`;
    }).join("\n\n---\n\n");
  }

  if(mode === "carousel4"){
    if(!sel.quote){ alert("Paste a quote for Carousel Generator."); return; }
    rows = buildCarousel4(DATA);

    const postCaption = `POST CAPTION\n${buildContent(sel).caption}\n\nCOMMENT HOOK\n${buildContent(sel).hook}\n\nHASHTAGS\n${buildContent(sel).hashtags}\n\n`;
    const slides = rows.map((r, idx)=>{
      return `SLIDE ${idx+1}\n${r.slideText}\n\nPROMPT\n${r.prompt}`;
    }).join("\n\n---\n\n");

    $("output").textContent = postCaption + "\n" + slides;
  }

  if(mode === "pack10"){
    if(!sel.quote){ alert("Paste a quote for 10-Pack."); return; }
    rows = buildPackN(DATA, 10, "Pack");

    $("output").textContent = rows.map(r=>{
      return sel.contentMode
        ? `${r.label}\nPROMPT\n${r.prompt}\n\nCAPTION\n${r.caption}\n\nHOOK\n${r.hook}\n\nHASHTAGS\n${r.hashtags}`
        : `${r.label}\n${r.prompt}`;
    }).join("\n\n---\n\n");
  }

  if(mode === "pack30"){
    drop = buildDrop(DATA);
    rows = drop.rows;

    $("output").textContent = rows.map(r=>{
      return sel.contentMode
        ? `${r.label}\nPROMPT\n${r.prompt}\n\nCAPTION\n${r.caption}\n\nHOOK\n${r.hook}\n\nHASHTAGS\n${r.hashtags}`
        : `${r.label}\n${r.prompt}`;
    }).join("\n\n---\n\n");
  }

  if(mode === "dropbuilder"){
    drop = buildDrop(DATA);
    rows = drop.rows;

    const header = `DROP NAME\n${drop.dropName}\n\nDROP THEME\n${drop.dropTheme}\n\nQUOTE (optional)\n${drop.quoteReference || "(none)"}\n\n=== OUTPUT ===\n`;
    const body = rows.map(r=>{
      return sel.contentMode
        ? `${r.label}\nPROMPT\n${r.prompt}\n\nCAPTION\n${r.caption}\n\nHOOK\n${r.hook}\n\nHASHTAGS\n${r.hashtags}`
        : `${r.label}\n${r.prompt}`;
    }).join("\n\n---\n\n");

    $("output").textContent = header + "\n" + body;
  }

  if(mode === "batch5"){
    rows = [];
    for(let i=0;i<5;i++){
      randomizeAll(DATA);
      const s = getSelections();
      const prompt = buildSinglePrompt(s);
      const content = s.contentMode ? buildContent(s) : null;

      rows.push({
        label:`Random ${i+1}`,
        dropName:"",
        dropTheme:"",
        quoteReference:"",
        prompt,
        caption: content?.caption || "",
        hook: content?.hook || "",
        hashtags: content?.hashtags || "",
        slideText:""
      });
    }

    $("output").textContent = rows.map(r=>{
      return sel.contentMode
        ? `${r.label}\nPROMPT\n${r.prompt}\n\nCAPTION\n${r.caption}\n\nHOOK\n${r.hook}\n\nHASHTAGS\n${r.hashtags}`
        : `${r.label}\n${r.prompt}`;
    }).join("\n\n---\n\n");
  }

  window.__lastRows = rows;
  window.__lastDrop = drop;
});

